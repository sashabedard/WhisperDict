# Normalize line endings: treat everything as text, auto-detect, LF in repo.
* text=auto eol=lf

# Source & config — always text.
*.swift   text
*.sh      text eol=lf
*.py      text
*.md      text
*.plist   text
*.resolved text

# Binary assets — never diffed, merged, or counted as text.
*.png     binary
*.icns    binary
*.dmg     binary
*.zip     binary

# Keep GitHub's language stats focused on the actual app code.
Scripts/**   linguist-vendored
*.plist      linguist-generated
